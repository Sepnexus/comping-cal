# ── VPS server .env — copy to `.env` on the box and fill in. Never commit. ──

# Domain Traefik routes to this container (DNS A record → VPS IP). The tool serves
# both the UI and /api from here.
PUBLIC_HOST=comps.srv844822.hstgr.cloud
TOOL_PUBLIC_URL=https://comps.srv844822.hstgr.cloud

# ── Server secrets — generate with:  openssl rand -hex 32 ──
HMAC_SECRET=CHANGE_ME_random_hex
ADMIN_JWT_SECRET=CHANGE_ME_random_hex

# Admin login created on first boot (seed). Use a strong password for production.
ADMIN_EMAIL=akshay@sepnexus.com
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Bricked.ai (live) ──
BRICKED_MODE=live
BRICKED_API_KEY=

# ── GoHighLevel — custom-JS button model (your endpoints) ──
GHL_MODE=live
GHL_CONTACT_URL=
GHL_CHARGE_URL=
GHL_WRITEBACK_URL=
GHL_API_KEY=

# Shared launch password baked into the GHL contact button (integrations/ghl-comp-button.js).
LAUNCH_PASSWORD=CHANGE_ME_shared_launch_secret

# ── Pricing / behaviour ──
DEFAULT_PER_COMP_PRICE=0.65
DEFAULT_BRICKED_COST=0.33
GLOBAL_COST_CEILING=300
AUTO_PROVISION_LOCATIONS=true
