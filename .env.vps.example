# ── VPS server .env — copy to `.env` on the box. Bootstrap minimum only. ──
# Everything else (Bricked key, GHL endpoints, launch password, pricing) is managed
# from Admin → Settings after you log in — no SSH/nano needed for those.

# Domain Traefik routes to this container (DNS A record → VPS IP). Serves UI + /api.
PUBLIC_HOST=comps.srv844822.hstgr.cloud
TOOL_PUBLIC_URL=https://comps.srv844822.hstgr.cloud

# Server secrets — generate each with:  openssl rand -hex 32
HMAC_SECRET=CHANGE_ME_random_hex
ADMIN_JWT_SECRET=CHANGE_ME_random_hex

# Admin login, created on first boot. Use a strong password.
ADMIN_EMAIL=akshay@sepnexus.com
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Optional: pre-seed integrations via env (or just set them in Admin → Settings) ──
# Live only — without GHL_CHARGE_URL every real location is blocked (no free comps).
# BRICKED_API_KEY=
# GHL_CONTACT_URL=
# GHL_LOCATION_URL=
# GHL_CHARGE_URL=https://n8n.srv844822.hstgr.cloud/webhook/payment
# GHL_WRITEBACK_URL=
# GHL_API_KEY=
# LAUNCH_PASSWORD=
