# ── Server ──────────────────────────────────────────────────────────────────
PORT=8787

# HMAC server secret. Per-location button token = HMAC_SHA256(HMAC_SECRET, locationId).
# Keep this server-side only — it is the root of the v1 auth scheme (FRD §4.2).
HMAC_SECRET=dev-hmac-secret-change-me

# Admin panel JWT signing secret.
ADMIN_JWT_SECRET=dev-admin-jwt-secret-change-me

# ── External adapters ────────────────────────────────────────────────────────
# Bricked.ai. When BRICKED_MODE=live, real calls are made with BRICKED_API_KEY.
# In mock mode (default) the adapter returns realistic comp data with no network.
BRICKED_MODE=mock
BRICKED_API_KEY=
BRICKED_BASE_URL=https://api.bricked.ai

# GoHighLevel — custom-JS button model (no marketplace app / OAuth / SSO). When
# GHL_MODE=live, contact fetch / per-comp charge / write-back POST to the agency's
# own endpoints below. Mock mode simulates all three.
GHL_MODE=mock
GHL_CONTACT_URL=        # GET contact (name, address) by ?locationId=&contactId=
GHL_CHARGE_URL=         # POST per-comp charge → { status: success|failed, reason }
GHL_WRITEBACK_URL=      # POST { locationId, contactId, fields } to push values back
GHL_API_KEY=           # sent as x-api-key on the three calls above

# Shared launch password baked into the GHL custom-JS button (integrations/
# ghl-comp-button.js). A launch is valid when its token equals this. Keep it secret.
LAUNCH_PASSWORD=

# Public origin where the tool is hosted (used in the custom-JS button + admin links).
TOOL_PUBLIC_URL=

# Default per-comp price charged to a sub-account wallet, and our Bricked cost,
# used for margin reporting when a location has no override (FRD §6.4 / §8.1.1).
DEFAULT_PER_COMP_PRICE=0.65
DEFAULT_BRICKED_COST=0.33
GLOBAL_COST_CEILING=300

# When true, a request bearing a valid per-location token for an unknown locationId
# auto-registers that sub-account (active, unnamed) so it works on first launch.
# Set false to require every location to be added to the allowlist first (FRD §4.3).
AUTO_PROVISION_LOCATIONS=true

# Public origin used to build per-location launch URLs in the admin panel.
# Leave empty to derive it from the admin's browser origin.
PUBLIC_BASE_URL=

# ── Web ──────────────────────────────────────────────────────────────────────
# Where the frontend reaches the backend (used by Vite dev proxy).
VITE_API_BASE=/api
