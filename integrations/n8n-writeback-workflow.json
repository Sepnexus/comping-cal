        "dataTableId": {
          "__rl": true,
          "value": "kshVbfaHvr6ICAhg",
          "mode": "list",
          "cachedResultName": "GHL outh details"
        },
        "filters": {
          "conditions": [
            {
              "keyName": "locationid",
              "keyValue": "={{ $json.body.locationId }}"
            }
          ]
        }
